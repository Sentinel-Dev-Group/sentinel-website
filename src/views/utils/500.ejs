<%- include('../_partials/header', { Title: "Server Error", User, Settings }) %>
<div class="flex-1 flex items-center justify-center p-4 sm:p-6">
  <div class="w-full max-w-md text-center">
    <div class="bg-white/5 border border-red-500/20 rounded-2xl p-8 backdrop-blur-xl">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center">
        <i class="fas fa-exclamation-triangle text-3xl text-red-500"></i>
      </div>
      <h1 class="text-2xl font-bold text-white mb-2">500 - Server Error</h1>
      <p class="text-gray-400 mb-6">Oops! Something went wrong on our end.</p>
      <% if (Error) { %>
        <div class="bg-black/20 p-4 rounded-lg text-left mb-6 overflow-auto max-h-40">
          <code class="text-xs text-red-400"><%= Error %></code>
        </div>
      <% } %>
      <div class="space-y-3">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition-colors duration-200">
          <i class="fas fa-home mr-2"></i> Return Home
        </a>
        <button onclick="window.history.back()" class="w-full text-sm text-blue-400 hover:text-blue-300 transition-colors">
          <i class="fas fa-arrow-left mr-1"></i> Go Back
        </button>
      </div>
    </div>
  </div>
</div>
<%- include('../_partials/footer') %>