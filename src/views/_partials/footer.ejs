          </div>

        </div>

        <!-- Bottom bar -->
        <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-gray-600 text-xs">
            <%- Settings.footer || `© ${new Date().getFullYear()} ${Settings.name}. All rights reserved.` %>
          </p>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-gray-600 text-xs">All systems operational</span>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <!-- Toast container -->
  <div id="toast" class="fixed bottom-4 right-4 z-50 flex flex-col items-end"></div>

  <script>
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      const icon = document.getElementById('menu-icon');
      menu.classList.toggle('open');
      icon.className = menu.classList.contains('open') ? 'fas fa-times' : 'fas fa-bars';
    }

    function ToggleModal(id, show) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.toggle('hidden', !show);
      el.classList.toggle('block', show);
    }

    // Show error from URL param on login page
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');
    if (error) {
      const toast = document.getElementById('toast');
      if (toast) {
        const el = document.createElement('div');
        el.className = 'bg-red-500 text-white text-sm font-medium px-4 py-3 rounded-xl shadow-lg mb-2';
        el.textContent = decodeURIComponent(error);
        toast.appendChild(el);
        setTimeout(() => el.remove(), 5000);
      }
    }

    // Show success message after purchase redirect
    const purchase = urlParams.get('purchase');
    if (purchase === 'success') {
      const toast = document.getElementById('toast');
      if (toast) {
        const el = document.createElement('div');
        el.className = 'bg-green-500 text-white text-sm font-medium px-4 py-3 rounded-xl shadow-lg mb-2';
        el.textContent = '🎉 Purchase successful! Your license key is ready in your dashboard.';
        toast.appendChild(el);
        setTimeout(() => el.remove(), 6000);
      }
    }
  </script>
</body>
</html>