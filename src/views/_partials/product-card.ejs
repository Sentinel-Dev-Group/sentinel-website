<% 
  let images = [];
  try { images = JSON.parse(product.images || '[]'); } catch(e) {}
  const thumb = images[0] || '/img/placeholder.png';
%>
<a href="/product/<%= product.slug %>"
   class="group relative flex flex-col bg-white/3 hover:bg-white/5 border border-white/8 hover:border-cyan-500/30 rounded-2xl overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-cyan-500/5">

  <!-- Featured badge -->
  <% if (product.featured) { %>
    <div class="absolute top-3 left-3 z-10 px-2 py-0.5 bg-cyan-500 text-black text-xs font-bold rounded-full">
      Featured
    </div>
  <% } %>

  <!-- Category badge -->
  <% if (product.category_name) { %>
    <div class="absolute top-3 right-3 z-10 px-2 py-0.5 bg-black/60 backdrop-blur text-cyan-400 text-xs rounded-full border border-cyan-500/20">
      <%= product.category_name %>
    </div>
  <% } %>

  <!-- Thumbnail -->
  <div class="w-full h-44 bg-gradient-to-br from-cyan-900/20 to-blue-900/20 overflow-hidden">
    <img src="<%= thumb %>"
         alt="<%= product.name %>"
         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
         onerror="this.src='/img/placeholder.png'">
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h3 class="font-bold text-white text-lg mb-1 group-hover:text-cyan-300 transition-colors line-clamp-1">
      <%= product.name %>
    </h3>
    <p class="text-gray-400 text-sm line-clamp-2 flex-1 mb-4">
      <%= product.description || 'No description provided.' %>
    </p>

    <div class="flex items-center justify-between mt-auto">
      <div>
        <span class="text-2xl font-black text-white">£<%= parseFloat(product.price).toFixed(2) %></span>
      </div>
      <div class="flex items-center gap-3">
        <% if (product.sales > 0) { %>
          <span class="text-xs text-gray-500">
            <i class="fas fa-download mr-1"></i><%= product.sales %> sold
          </span>
        <% } %>
        <span class="px-3 py-1.5 bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-500/20 text-cyan-400 text-xs font-semibold rounded-lg transition-colors">
          View →
        </span>
      </div>
    </div>
  </div>
</a>