<%- include('_partials/header', { Title: 'Store', User, Settings }) %>

<!-- Page header -->
<div class="border-b border-white/5 bg-white/2">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-black mb-1">Store</h1>
    <p class="text-gray-400 text-sm">Browse our full collection of plugins and mods.</p>
  </div>
</div>

<!-- Filters -->
<div class="border-b border-white/5 bg-black/40 sticky top-0 z-20 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-6 py-3 flex flex-wrap items-center gap-3">

    <!-- Category tabs -->
    <a href="/store"
       class="px-3 py-1.5 text-sm rounded-lg border transition-all <%= !category ? 'border-cyan-500 text-cyan-400 bg-cyan-500/10' : 'border-white/10 text-gray-400 hover:border-white/30 hover:text-white' %>">
      All
    </a>
    <% categories.forEach(function(cat) { %>
      <a href="/store?category=<%= cat.slug %><%= search ? '&search=' + search : '' %>"
         class="px-3 py-1.5 text-sm rounded-lg border transition-all <%= category === cat.slug ? 'border-cyan-500 text-cyan-400 bg-cyan-500/10' : 'border-white/10 text-gray-400 hover:border-white/30 hover:text-white' %>">
        <i class="fas <%= cat.icon %> mr-1.5"></i><%= cat.name %>
      </a>
    <% }); %>

    <!-- Search -->
    <form method="GET" action="/store" class="ml-auto flex items-center gap-2">
      <% if (category) { %>
        <input type="hidden" name="category" value="<%= category %>">
      <% } %>
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
        <input type="text"
               name="search"
               value="<%= search %>"
               placeholder="Search products..."
               class="w-56 bg-white/5 border border-white/10 rounded-lg py-1.5 pl-8 pr-4 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500/50 transition-colors">
      </div>
      <button type="submit"
              class="px-3 py-1.5 bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm rounded-lg hover:bg-cyan-500/20 transition-colors">
        Search
      </button>
      <% if (search) { %>
        <a href="/store<%= category ? '?category=' + category : '' %>"
           class="px-3 py-1.5 border border-white/10 text-gray-400 text-sm rounded-lg hover:border-white/30 transition-colors">
          Clear
        </a>
      <% } %>
    </form>
  </div>
</div>

<!-- Results -->
<div class="max-w-7xl mx-auto px-6 py-10">

  <!-- Result count -->
  <p class="text-sm text-gray-500 mb-6">
    <% if (search) { %>
      <%= products.length %> result<%= products.length !== 1 ? 's' : '' %> for "<span class="text-white"><%= search %></span>"
      <% if (category) { %> in <span class="text-cyan-400"><%= categories.find(c => c.slug === category)?.name %></span><% } %>
    <% } else if (category) { %>
      Showing <span class="text-white"><%= categories.find(c => c.slug === category)?.name %></span>
      — <%= products.length %> product<%= products.length !== 1 ? 's' : '' %>
    <% } else { %>
      <%= products.length %> product<%= products.length !== 1 ? 's' : '' %> available
    <% } %>
  </p>

  <!-- Grid -->
  <% if (products.length === 0) { %>
    <div class="text-center py-28">
      <i class="fas fa-search text-4xl text-gray-700 mb-4 block"></i>
      <p class="text-gray-400 font-medium mb-2">No products found</p>
      <p class="text-gray-600 text-sm mb-6">Try a different search term or category.</p>
      <a href="/store" class="px-4 py-2 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-white hover:border-white/30 transition-colors">
        Clear filters
      </a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% products.forEach(function(product) { %>
        <%- include('_partials/product-card', { product, User }) %>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('_partials/footer', { User, Settings }) %>