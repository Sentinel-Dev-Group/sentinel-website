<%- include('_partials/header', { Title: 'Dashboard', User, Settings }) %>

<div class="max-w-7xl mx-auto px-6 py-10">

  <!-- Page header -->
  <div class="flex items-center justify-between mb-10">
    <div class="flex items-center gap-4">
      <img src="<%= User.userImage %>" alt="<%= User.userName %>"
           class="w-14 h-14 rounded-full border-2 border-cyan-500/30"
           onerror="this.src='/img/placeholder.png'">
      <div>
        <h1 class="text-2xl font-black">Welcome back, <%= User.userName %></h1>
        <p class="text-gray-400 text-sm"><%= User.userEmail %></p>
      </div>
    </div>
    <a href="/store"
       class="px-4 py-2 bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm rounded-xl hover:bg-cyan-500/20 transition-colors">
      <i class="fas fa-store mr-2"></i>Browse Store
    </a>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
    <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
      <p class="text-3xl font-black text-cyan-400"><%= licenses.length %></p>
      <p class="text-gray-500 text-sm mt-1">Products owned</p>
    </div>
    <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
      <p class="text-3xl font-black text-cyan-400"><%= licenses.filter(l => l.status === 'active').length %></p>
      <p class="text-gray-500 text-sm mt-1">Active licenses</p>
    </div>
    <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
      <p class="text-3xl font-black text-cyan-400"><%= orders.length %></p>
      <p class="text-gray-500 text-sm mt-1">Orders placed</p>
    </div>
    <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
      <p class="text-3xl font-black text-cyan-400">
        £<%= orders.reduce((sum, o) => sum + parseFloat(o.total || 0), 0).toFixed(2) %>
      </p>
      <p class="text-gray-500 text-sm mt-1">Total spent</p>
    </div>
  </div>

  <!-- Success banner -->
  <% if (typeof query !== 'undefined' && query.purchase === 'success' || (locals.query && locals.query.purchase === 'success')) { %>
  <% } %>
  <% if (new URLSearchParams(locals._parsedUrl ? locals._parsedUrl.query : '').get('purchase') === 'success') { %>
  <% } %>

  <!-- Licenses -->
  <div class="mb-12">
    <h2 class="text-xl font-bold mb-5 flex items-center gap-2">
      <i class="fas fa-key text-cyan-400"></i> Your Licenses
    </h2>

    <% if (licenses.length === 0) { %>
      <div class="text-center py-16 bg-white/2 border border-white/5 rounded-2xl">
        <i class="fas fa-box-open text-4xl text-gray-700 mb-4 block"></i>
        <p class="text-gray-400 font-medium mb-2">No licenses yet</p>
        <p class="text-gray-600 text-sm mb-6">Head to the store to purchase your first plugin or mod.</p>
        <a href="/store"
           class="px-5 py-2.5 bg-cyan-500 hover:bg-cyan-400 text-black font-bold rounded-xl text-sm transition-all">
          Browse Store
        </a>
      </div>
    <% } else { %>
      <div class="flex flex-col gap-4">
        <% licenses.forEach(function(license) { %>
          <%
            const statusColor = {
              active: 'text-green-400 bg-green-500/10 border-green-500/20',
              suspended: 'text-red-400 bg-red-500/10 border-red-500/20',
              expired: 'text-gray-400 bg-gray-500/10 border-gray-500/20'
            }[license.status] || 'text-gray-400 bg-gray-500/10 border-gray-500/20';

            const thumb = (() => {
              try {
                const imgs = JSON.parse(license.images || '[]');
                return imgs[0] || '/img/placeholder.png';
              } catch(e) { return '/img/placeholder.png'; }
            })();
          %>
          <div class="bg-white/3 border border-white/8 hover:border-white/12 rounded-2xl p-5 transition-all">
            <div class="flex flex-col sm:flex-row sm:items-center gap-4">

              <!-- Product thumbnail -->
              <img src="<%= thumb %>"
                   alt="<%= license.product_name %>"
                   class="w-16 h-16 rounded-xl object-cover border border-white/10 flex-shrink-0"
                   onerror="this.src='/img/placeholder.png'">

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <h3 class="font-bold text-white"><%= license.product_name %></h3>
                  <span class="px-2 py-0.5 text-xs rounded-full border <%= statusColor %>">
                    <%= license.status %>
                  </span>
                  <% if (license.version) { %>
                    <span class="px-2 py-0.5 text-xs rounded-full border border-white/10 text-gray-400">
                      v<%= license.version %>
                    </span>
                  <% } %>
                </div>

                <!-- License key -->
                <div class="flex items-center gap-2 mb-2">
                  <code id="key-<%= license.key %>"
                        class="text-xs font-mono text-cyan-300 bg-black/40 px-2 py-1 rounded-lg border border-white/8 select-all">
                    <%= license.key %>
                  </code>
                  <button onclick="copyKey('<%= license.key %>')"
                          class="text-gray-500 hover:text-cyan-400 transition-colors text-xs"
                          title="Copy key">
                    <i class="fas fa-copy"></i>
                  </button>
                </div>

                <!-- Meta -->
                <div class="flex flex-wrap gap-4 text-xs text-gray-500">
                  <span><i class="fas fa-calendar mr-1"></i>
                    <%= new Date(license.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </span>
                  <% if (license.hwid) { %>
                    <span><i class="fas fa-microchip mr-1"></i>HWID locked</span>
                  <% } else { %>
                    <span class="text-yellow-500/70"><i class="fas fa-microchip mr-1"></i>Not yet bound</span>
                  <% } %>
                  <span><i class="fas fa-download mr-1"></i><%= license.uses %> use<%= license.uses !== 1 ? 's' : '' %></span>
                  <% if (license.expires_at) { %>
                    <span class="text-orange-400"><i class="fas fa-clock mr-1"></i>
                      Expires <%= new Date(license.expires_at).toLocaleDateString('en-GB') %>
                    </span>
                  <% } else { %>
                    <span class="text-green-500/70"><i class="fas fa-infinity mr-1"></i>Lifetime</span>
                  <% } %>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex flex-col sm:items-end gap-2 flex-shrink-0">
                <% if (license.status === 'active' && license.filename) { %>
                  <a href="/download/<%= license.product_id %>"
                     class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-black text-sm font-bold rounded-xl transition-all hover:scale-105 flex items-center gap-2">
                    <i class="fas fa-download"></i> Download
                  </a>
                <% } else if (license.status === 'active' && !license.filename) { %>
                  <span class="px-4 py-2 bg-white/5 border border-white/10 text-gray-500 text-sm rounded-xl cursor-not-allowed">
                    No file yet
                  </span>
                <% } %>
                <a href="/product/<%= license.product_slug %>"
                   class="text-xs text-gray-500 hover:text-cyan-400 transition-colors">
                  View product →
                </a>
              </div>

            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Order history -->
  <div>
    <h2 class="text-xl font-bold mb-5 flex items-center gap-2">
      <i class="fas fa-receipt text-cyan-400"></i> Order History
    </h2>

    <% if (orders.length === 0) { %>
      <div class="text-center py-10 bg-white/2 border border-white/5 rounded-2xl text-gray-600 text-sm">
        No orders yet.
      </div>
    <% } else { %>
      <div class="bg-white/3 border border-white/8 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/8 text-gray-500 text-xs uppercase tracking-wide">
              <th class="text-left px-5 py-3">Order ID</th>
              <th class="text-left px-5 py-3">Products</th>
              <th class="text-left px-5 py-3">Date</th>
              <th class="text-left px-5 py-3">Status</th>
              <th class="text-right px-5 py-3">Total</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(function(order) { %>
              <tr class="border-b border-white/5 last:border-0 hover:bg-white/2 transition-colors">
                <td class="px-5 py-4">
                  <code class="text-xs text-gray-400 font-mono"><%= order.id.substring(0, 8) %>...</code>
                </td>
                <td class="px-5 py-4 text-gray-300"><%= order.products %></td>
                <td class="px-5 py-4 text-gray-400">
                  <%= new Date(order.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="px-5 py-4">
                  <span class="px-2 py-0.5 text-xs rounded-full border
                    <%= order.status === 'completed' ? 'text-green-400 bg-green-500/10 border-green-500/20' :
                        order.status === 'refunded'  ? 'text-red-400 bg-red-500/10 border-red-500/20' :
                                                       'text-yellow-400 bg-yellow-500/10 border-yellow-500/20' %>">
                    <%= order.status %>
                  </span>
                </td>
                <td class="px-5 py-4 text-right font-bold text-white">
                  £<%= parseFloat(order.total).toFixed(2) %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

</div>

<script>
function copyKey(key) {
  navigator.clipboard.writeText(key).then(function() {
    showToast('License key copied!', 'success');
  }).catch(function() {
    showToast('Failed to copy key', 'error');
  });
}

function showToast(message, type) {
  const toast = document.getElementById('toast');
  const color = type === 'success' ? 'bg-green-500' : 'bg-red-500';
  const el = document.createElement('div');
  el.className = `${color} text-white text-sm font-medium px-4 py-3 rounded-xl shadow-lg mb-2 transition-all`;
  el.textContent = message;
  toast.appendChild(el);
  setTimeout(function() { el.remove(); }, 3000);
}
</script>

<%- include('_partials/footer', { User, Settings }) %>