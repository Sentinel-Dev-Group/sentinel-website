<%- include('_partials/header', { Title: 'Home', User, Settings }) %>

<!-- Hero -->
<section class="relative overflow-hidden border-b border-white/5">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_#0e7490_0%,_transparent_60%)] opacity-30"></div>
  <div class="relative max-w-7xl mx-auto px-6 py-28 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 text-xs font-medium mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
      Premium Plugins & Mods
    </div>
    <h1 class="text-5xl sm:text-6xl font-black tracking-tight mb-6">
      Built for
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">serious</span>
      server owners
    </h1>
    <p class="text-gray-400 text-lg max-w-xl mx-auto mb-10">
      <%= Settings.dest %>
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/store" class="px-6 py-3 bg-cyan-500 hover:bg-cyan-400 text-black font-bold rounded-xl transition-all duration-200 hover:scale-105">
        Browse Store
      </a>
      <a href="/store?category=minecraft" class="px-6 py-3 border border-white/10 hover:border-white/30 text-white rounded-xl transition-all duration-200">
        Minecraft Plugins
      </a>
      <a href="/store?category=dayz" class="px-6 py-3 border border-white/10 hover:border-white/30 text-white rounded-xl transition-all duration-200">
        DayZ Mods
      </a>
    </div>
  </div>
</section>

<!-- Stats bar -->
<div class="border-b border-white/5 bg-white/2">
  <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap justify-center gap-10">
    <div class="text-center">
      <p class="text-2xl font-bold text-cyan-400"><%= products.length %>+</p>
      <p class="text-xs text-gray-500 mt-0.5">Products</p>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-cyan-400"><%= categories.length %></p>
      <p class="text-xs text-gray-500 mt-0.5">Categories</p>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-cyan-400">24/7</p>
      <p class="text-xs text-gray-500 mt-0.5">Support</p>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-cyan-400">instant</p>
      <p class="text-xs text-gray-500 mt-0.5">Delivery</p>
    </div>
  </div>
</div>

<!-- Featured products -->
<% if (products.some(p => p.featured)) { %>
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold">Featured</h2>
    <a href="/store" class="text-cyan-400 hover:text-cyan-300 text-sm transition-colors">View all →</a>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% products.filter(p => p.featured).forEach(function(product) { %>
      <%- include('_partials/product-card', { product, User }) %>
    <% }); %>
  </div>
</section>
<% } %>

<!-- All products -->
<section class="max-w-7xl mx-auto px-6 pb-20">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold">All Products</h2>
    <div class="flex gap-2">
      <% categories.forEach(function(cat) { %>
        <a href="/store?category=<%= cat.slug %>"
           class="px-3 py-1.5 text-xs border border-white/10 hover:border-cyan-500/50 hover:text-cyan-400 rounded-lg transition-all">
          <i class="fas <%= cat.icon %> mr-1"></i><%= cat.name %>
        </a>
      <% }); %>
    </div>
  </div>

  <% if (products.length === 0) { %>
    <div class="text-center py-24 text-gray-500">
      <i class="fas fa-box-open text-4xl mb-4 block"></i>
      No products available yet. Check back soon.
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% products.forEach(function(product) { %>
        <%- include('_partials/product-card', { product, User }) %>
      <% }); %>
    </div>
  <% } %>
</section>

<%- include('_partials/footer', { User, Settings }) %>